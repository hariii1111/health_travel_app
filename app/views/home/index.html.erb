<% unless user_signed_in? %>
  <!-- ▼▼ ログイン前：タイトル画面 ▼▼ -->
  <div class="home-container">
    <h1 class="app-title">Move Journey</h1>
    <p class="app-subtitle">歩くたび、日本をめぐる。</p>

    <div class="home-buttons">
      <%= link_to "ログインはこちら", new_user_session_path, class: "home-btn primary" %>
      <%= link_to "新規登録はこちら", new_user_registration_path, class: "home-btn secondary" %>
    </div>
  </div>

  <% return %>
<% end %>

<!-- ▼▼ ログイン後：ダッシュボード（今まで通り） ▼▼ -->
<div class="dashboard-container">
  <h2>ダッシュボード</h2>

  <% if @exercises.any? %>
    <% @exercises.each do |exercise| %>
      <p><%= exercise.minutes %> 分 / <%= exercise.mets %> METs</p>
    <% end %>
  <% else %>
    <p>まだ運動記録がありません。</p>
  <% end %>
</div>
