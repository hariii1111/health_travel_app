<h2>運動記録を追加</h2>

<%= form_with model: @exercise do |f| %>
  <div>
    <%= f.label :minutes, "運動時間（分）" %>
    <%= f.number_field :minutes, min: 0, step: 1 %>
  </div>

  <div class="field">
    <%= f.label :mets, "運動強度（METs）" %>
    <%= f.select :mets, [
      ["1.0：座位（座っている状態）", 1.0],
      ["2.8：ゆっくり歩く", 2.8],
      ["3.3：普通歩行", 3.3],
      ["4.3：早歩き", 4.3],
      ["8.0：ランニング（軽め）", 8.0],
      ["10.0：ランニング（中程度）", 10.0],
      ["12.0：ランニング（強め）", 12.0],
      ["4.0：自転車（軽め）", 4.0],
      ["6.0：自転車（中程度）", 6.0],
      ["8.0：自転車（強め）", 8.0]
    ] %>

    <p class="note">
      ※ METs（運動強度）とは？<br>
      1.0：座っている状態<br>
      2.8：ゆっくり歩く<br>
      3.3：普通歩行<br>
      4.3：早歩き<br>
      8.0〜12.0：ランニング<br>
      4.0〜8.0：自転車
    </p>
  </div>

  <%= f.submit "記録する" %>
<% end %>
