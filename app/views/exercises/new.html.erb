<h2>運動記録を追加</h2>

<% if @exercise.errors.any? %>
  <div class="alert alert-danger">
    <p><strong><%= @exercise.errors.count %> 件のエラーがあります</strong></p>
    <ul>
      <% @exercise.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @exercise do |f| %>

  <div class="field">
    <%= f.label :minutes, "運動時間（分）" %>
    <%= f.number_field :minutes, min: 0, step: 1 %>
  </div>

  <div class="field">
    <%= f.label :mets, "運動強度（METs）" %>
    <%= f.select :mets, [
      ["1.0：座位（座っている状態）", 1.0],
      ["2.8：ゆっくり歩く", 2.8],
      ["3.3：普通歩行", 3.3],
      ["4.0：自転車（軽め）", 4.0],
      ["4.3：早歩き", 4.3],
      ["6.0：自転車（中程度）", 6.0],
      ["8.0：ランニング（軽め）", 8.0],
      ["8.0：自転車（強め）", 8.0],
      ["10.0：ランニング（中程度）", 10.0],
      ["12.0：ランニング（強め）", 12.0]
    ] %>

    <p class="note">
      ※ METs（運動強度）とは、運動のきつさを表す数字です。<br>
      1.0＝座位（座っている状態）<br>
      2.8＝ゆっくり歩く<br>
      3.3＝普通歩行<br>
      4.0＝自転車（軽め）<br>
      4.3＝早歩き<br>
      6.0＝自転車（中程度）<br>
      8.0＝ランニング（軽め） / 自転車（強め）<br>
      10.0＝ランニング（中程度）<br>
      12.0＝ランニング（強め）
    </p>
  </div>

  <%= f.submit "記録する" %>

<% end %>
