<%- if controller_name != 'sessions' %>
  <p><%= link_to "ログインはこちら", new_session_path(resource_name) %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p><%= link_to "新規登録はこちら", new_registration_path(resource_name) %></p>
<% end %>

<%# パスワードリセットは無効化しているため非表示 %>
<%# メール確認機能も使用しないため非表示 %>
<%# アカウントロック解除も使用しないため非表示 %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p><%= button_to "#{OmniAuth::Utils.camelize(provider)} でログイン", omniauth_authorize_path(resource_name, provider), data: { turbo: false } %></p>
  <% end %>
<% end %>
