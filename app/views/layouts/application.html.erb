<!DOCTYPE html>
<html>
  <head>
  <title><%= content_for(:title) || "App" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>


  <body>

    <!-- ヘッダー（ログイン中のユーザー名のみ） -->
<header style="padding: 10px; background: #f5f5f5;">
  <% if user_signed_in? %>
    <span><%= current_user.email %> さんでログイン中</span>
  <% end %>
</header>

<div style="max-width: 600px; margin: 0 auto; padding: 15px;">
  <%= yield %>
</div>


    <!-- 下部ナビ（ログイン時のみ表示） -->
<% if user_signed_in? %>
  <nav class="bottom-nav">
    <%= link_to "ホーム", authenticated_root_path,
          class: ["nav-item", ("active-nav" if current_page?(authenticated_root_path))] %>

    <%= link_to "ダッシュボード", dashboard_path,
          class: ["nav-item", ("active-nav" if current_page?(dashboard_path))] %>

    <%= link_to "マイページ", mypage_path,
          class: ["nav-item", ("active-nav" if current_page?(mypage_path))] %>

    <!-- ログアウト -->
    <form action="<%= destroy_user_session_path %>" method="post" style="display:inline;">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <input type="hidden" name="_method" value="delete">
      <button type="submit" class="nav-item" style="background:#e9e9e9;">
        ログアウト
      </button>
    </form>
  </nav>
<% end %>

  </body>
</html>
